{
  "name": "@repo/ui",
  "type": "module",
  "version": "0.3.0",
  "description": "An extension library for Mantine DataTable, providing powerful and easy-to-use features for building data tables in React applications.",
  "tags": [
    "mantine",
    "datatable",
    "react",
    "typescript",
    "data-table",
    "table-component",
    "react-table"
  ],
  "repository": "hoaaq/mantine-datatable-extended",
  "homepage": "https://mantine-datatable-extended.hoaaq.dev/",
  "bugs": {
    "url": "https://github.com/hoaaq/mantine-datatable-extended/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Au Quoc Hoa",
    "email": "hoaauquoc@gmail.com",
    "url": "https://hoaaq.dev"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.cjs"
    },
    "./styles.css": {
      "development": "./src/style.css",
      "default": "./dist/index.css"
    },
    "./styles.layer.css": {
      "development": "./src/styles.layer.css",
      "default": "./dist/styles.layer.css"
    }
  },
  "files": [
    "./dist",
    "./README.md",
    "./LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tsup": "^8.0.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@dnd-kit/react": ">=0.3",
    "@mantine/core": ">=8.3",
    "@mantine/dates": ">=8.3",
    "@mantine/hooks": ">=8.3",
    "@tabler/icons-react": ">=3.35",
    "clsx": ">=2",
    "dayjs": ">=1.11",
    "mantine-datatable": ">=8.3",
    "nuqs": ">=2.8",
    "react": ">=19",
    "react-dom": ">=19",
    "zod": ">=4.1"
  },
  "sideEffects": false
}
